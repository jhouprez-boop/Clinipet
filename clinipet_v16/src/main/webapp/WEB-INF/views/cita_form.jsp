<%@page contentType="text/html" pageEncoding="UTF-8"%><%@ page import="java.util.*" %>
<% List<Map<String,Object>> mascotas=(List<Map<String,Object>>)request.getAttribute("mascotas"); List<Map<String,Object>> veterinarios=(List<Map<String,Object>>)request.getAttribute("veterinarios"); if(mascotas==null)mascotas=new ArrayList<>(); if(veterinarios==null)veterinarios=new ArrayList<>(); %>
<!doctype html><html lang="es"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Agendar cita | CliniPet</title><link href="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta20/dist/css/tabler.min.css" rel="stylesheet"><link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" rel="stylesheet"><link href="https://fonts.googleapis.com/css2?family=Nunito:wght@500;700;800;900&family=Fredoka:wght@600;700&display=swap" rel="stylesheet"><style>body{min-height:100vh;background:linear-gradient(135deg,#f8fffb,#eafff4);font-family:Nunito,sans-serif;padding:40px}.cardx{max-width:900px;margin:auto;background:white;border-radius:34px;padding:34px;box-shadow:0 24px 70px rgba(0,80,50,.13)}h1{font-family:Fredoka,sans-serif;color:#003d25}.form-control,.form-select{border-radius:16px;padding:13px}.btn-main{border:0;border-radius:18px;background:linear-gradient(135deg,#00c875,#00f5a0);color:#003d25;font-weight:900;padding:13px 18px}</style></head><body><div class="cardx"><h1><i class="ti ti-calendar-plus text-success"></i> Agendar cita</h1><p class="text-secondary fw-bold">El sistema valida si la mascota ya tiene cita pendiente y si el doctor está ocupado.</p><% if(request.getParameter("error")!=null){ %><div class="alert alert-danger rounded-4"><%= request.getParameter("error") %></div><% } %><form method="post" action="${pageContext.request.contextPath}/citas/nueva"><div class="row g-3"><div class="col-md-6"><label class="form-label fw-bold">Mascota</label><select class="form-select" name="id_mascota" required><% for(Map<String,Object> m:mascotas){ %><option value="<%= m.get("id") %>"><%= m.get("nombre") %> - <%= m.get("duenio") %> (<%= m.get("alerta") %>)</option><% } %></select></div><div class="col-md-6"><label class="form-label fw-bold">Doctor</label><select class="form-select" name="id_veterinario"><option value="">Sin asignar</option><% for(Map<String,Object> v:veterinarios){ %><option value="<%= v.get("id") %>"><%= v.get("nombre") %> - <%= v.get("estado") %></option><% } %></select></div><div class="col-md-4"><label class="form-label fw-bold">Fecha</label><input class="form-control" type="date" name="fecha" id="fechaAdmin" required></div><div class="col-md-4"><label class="form-label fw-bold">Hora</label><input class="form-control" type="time" name="hora" id="horaAdmin" required></div><div class="col-md-4"><label class="form-label fw-bold">Precio</label><input class="form-control" type="number" name="precio" value="30000" min="0" required></div><div class="col-12"><label class="form-label fw-bold">Motivo</label><textarea class="form-control" name="motivo" rows="3" required></textarea></div><div class="col-12 d-flex gap-2"><button class="btn-main"><i class="ti ti-check"></i> Guardar cita</button><a class="btn btn-link fw-bold" href="${pageContext.request.contextPath}/dashboard">Volver</a></div></div></form></div><script src="${pageContext.request.contextPath}/assets/js/animations.js"></script><script>(function(){var now=new Date(),yyyy=now.getFullYear(),mm=String(now.getMonth()+1).padStart(2,"0"),dd=String(now.getDate()).padStart(2,"0"),hh=String(now.getHours()).padStart(2,"0"),mi=String(now.getMinutes()).padStart(2,"0"),today=yyyy+"-"+mm+"-"+dd,nowT=hh+":"+mi;var f=document.getElementById("fechaAdmin"),h=document.getElementById("horaAdmin");if(f)f.min=today;if(f&&h){f.addEventListener("change",function(){if(this.value===today){h.min=nowT;if(h.value&&h.value<nowT)h.value="";}else{h.min="";}});}})();</script>
</body></html>
