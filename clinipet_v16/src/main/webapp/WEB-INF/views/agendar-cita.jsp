<%@page contentType="text/html" pageEncoding="UTF-8"%>
<!doctype html><html lang="es"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Agendar cita | CliniPet</title><link href="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta20/dist/css/tabler.min.css" rel="stylesheet"><link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" rel="stylesheet"><link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&display=swap" rel="stylesheet"><style>body{font-family:Outfit,sans-serif;background:linear-gradient(135deg,#f7fffb,#eafff4)}.wrap{max-width:1050px;margin:40px auto;padding:18px}.panel{border:0;border-radius:34px;box-shadow:0 30px 90px rgba(0,93,58,.12);overflow:hidden}.head{padding:35px;background:linear-gradient(135deg,#003d25,#00c875);color:white}.form-control,.form-select{border-radius:16px;padding:12px}.btn-main{background:linear-gradient(135deg,#00c875,#00f5a0);border:0;color:#003d25;font-weight:900;border-radius:16px;padding:13px 22px}</style></head><body><div class="wrap"><div class="card panel"><div class="head"><h1><i class="ti ti-calendar-heart"></i> Agendar cita</h1><p class="mb-0 opacity-75">Completa los datos. La cita queda pendiente y aparece en el dashboard del administrador.</p></div><div class="card-body p-4"><% if(request.getAttribute("ok")!=null){ %><div class="alert alert-success"><%= request.getAttribute("ok") %></div><% } %><% if(request.getAttribute("error")!=null){ %><div class="alert alert-danger"><%= request.getAttribute("error") %></div><% } %><form method="post" action="${pageContext.request.contextPath}/citas/nueva"><div class="row g-3"><div class="col-md-6"><h3>Datos del dueño</h3><input name="duenio" class="form-control mb-3" placeholder="Nombre del dueño" value="<%= request.getAttribute("nombreUsuario") == null ? "" : request.getAttribute("nombreUsuario") %>" required><input name="documento" class="form-control mb-3" placeholder="Documento" required><input name="telefono" class="form-control mb-3" placeholder="Teléfono" required><input name="correo" type="email" class="form-control mb-3" placeholder="Correo" value="<%= request.getAttribute("correoUsuario") == null ? "" : request.getAttribute("correoUsuario") %>" required><input name="direccion" class="form-control mb-3" placeholder="Dirección"></div><div class="col-md-6"><h3>Datos de la mascota</h3><input name="mascota" class="form-control mb-3" placeholder="Nombre de la mascota" required><select name="especie" class="form-select mb-3" required><option value="Perro">Perro</option><option value="Gato">Gato</option><option value="Caballo">Caballo</option><option value="Vaca">Vaca</option><option value="Ave">Ave</option></select><input name="raza" class="form-control mb-3" placeholder="Raza"><select name="sexo" class="form-select mb-3"><option value="MACHO">Macho</option><option value="HEMBRA">Hembra</option></select><input name="fecha" type="date" class="form-control mb-3" required><input name="hora" type="time" class="form-control mb-3" required><textarea name="motivo" class="form-control mb-3" rows="3" placeholder="Motivo de la cita" required></textarea></div></div><div class="d-flex gap-2 justify-content-end"><a href="${pageContext.request.contextPath}/" class="btn btn-link">Volver</a><button class="btn btn-main"><i class="ti ti-check"></i> Agendar cita</button></div></form></div></div></div><script src="${pageContext.request.contextPath}/assets/js/animations.js"></script>
</body></html>
